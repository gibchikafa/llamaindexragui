# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Full URL of the RAG agent query endpoint
LLAMA_INDEX_AGENT_DEPLOYMENT_URL=http://<host>/v1/<project>/<agent-name>/query

# Hopsworks API key (Authorization: ApiKey <key>)
LLAMA_INDEX_AGENT_DEPLOYMENT_API_KEY=your-api-key-here

# Optional explicit subpath override. If omitted in Hopsworks, the app derives
# the mount from HOPSWORKS_PROJECT_NAME and HOPSWORKS_JOB_NAME.
# Use the public path without a trailing slash, for example:
#   NEXT_PUBLIC_BASE_PATH=/hopsworks-api/pythonapp/g2/myapp
# Leave empty when serving at the root.
NEXT_PUBLIC_BASE_PATH=
