# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Full URL of the RAG agent query endpoint
LLAMA_INDEX_AGENT_DEPLOYMENT_URL=http://<host>/v1/<project>/<agent-name>/query

# Hopsworks API key (Authorization: ApiKey <key>)
LLAMA_INDEX_AGENT_DEPLOYMENT_API_KEY=your-api-key-here

# Subpath where the app is served. Must be set at BUILD time.
# IMPORTANT: do NOT include a leading slash.
# e.g. for https://host/hopsworks-api/pythonappp/g2/myapp/ use:
#   NEXT_PUBLIC_BASE_PATH=hopsworks-api/pythonappp/g2/myapp
# Leave empty (or omit) when serving at the root.
NEXT_PUBLIC_BASE_PATH=
